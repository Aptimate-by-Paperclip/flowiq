NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Database — Vercel Postgres sets both automatically.
# DATABASE_URL uses the connection pooler (pgBouncer); DATABASE_URL_UNPOOLED is the direct connection.
# For local dev, set both to the same value.
DATABASE_URL=postgresql://postgres:password@localhost:5432/flowiq
DATABASE_URL_UNPOOLED=postgresql://postgres:password@localhost:5432/flowiq

# Cache — Vercel KV (Upstash) sets these automatically when the store is linked.
# KV_URL is the Redis-compatible connection string; use this with ioredis or the @vercel/kv client.
# For local dev, point at a local Redis instance.
KV_URL=redis://localhost:6379
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Auth (Clerk)
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx

# CORS
CORS_ORIGIN=http://localhost:3000
