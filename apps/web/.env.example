NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API
NEXT_PUBLIC_API_URL=http://localhost:3001

# Auth (Clerk) — get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Vercel Postgres (Neon) — set automatically when the Postgres store is linked in the Vercel dashboard.
# For local dev, point at your local PostgreSQL instance.
DATABASE_URL=postgresql://postgres:password@localhost:5432/flowiq
DATABASE_URL_UNPOOLED=postgresql://postgres:password@localhost:5432/flowiq
POSTGRES_URL=postgresql://postgres:password@localhost:5432/flowiq
POSTGRES_URL_NON_POOLING=postgresql://postgres:password@localhost:5432/flowiq
POSTGRES_HOST=localhost
POSTGRES_DATABASE=flowiq
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# Vercel KV (Upstash) — set automatically when the KV store is linked in the Vercel dashboard.
# For local dev, point at a local Redis instance.
KV_URL=redis://localhost:6379
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Vercel Blob — set automatically when the Blob store is linked in the Vercel dashboard.
BLOB_READ_WRITE_TOKEN=
